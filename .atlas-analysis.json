  "keyFeatures": [
    "YouTube content search and trending discovery",
    "Video and audio downloads with quality/format selection",
    "Offline library with local playback",
    "HTTP range streaming for smooth playback",
    "Download task management (list, cancel, delete, retry)",
    "Local thumbnail caching with automatic fallback",
    "Responsive UI with light/dark mode support",
    "FastAPI backend with yt-dlp integration",
    "Next.js 16 frontend with App Router",
    "Real-time download progress tracking"
  ],
  "publicApiSurface": [
    "POST /api/download - Start a video/audio download",
    "GET /api/downloads - List all download tasks",
    "GET /api/download/{download_id}/file - Download completed file",
    "DELETE /api/downloads/{download_id} - Cancel download",
    "DELETE /api/downloads/{download_id}/remove - Remove download and files",
    "GET /api/stream/{filename} - Stream local video file with range support",
    "GET /api/thumbnails/{task_id} - Get local thumbnail",
    "GET /api/search - Search YouTube videos",
    "GET /api/trending - Get trending videos",
    "POST /api/info - Get video metadata and available formats"
  ]
}
